        android:icon="@mipmap/ic_launcher"
        android:shortcutShortLabel="@string/shortcut_metronome_short"
        android:shortcutLongLabel="@string/shortcut_metronome_long">
        <intent
            android:action="android.intent.action.VIEW"
            android:targetPackage="com.insertclevernamehere.drumstrainer"
