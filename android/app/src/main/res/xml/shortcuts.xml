            android:action="android.intent.action.VIEW"
            android:targetPackage="com.insertclevernamehere.drumstrainer"
            android:targetClass="com.insertclevernamehere.drumstrainer.MainActivity"
            android:data="https://insertclevernamehere.github.io/Drums-Trainer/index.html?mode=groove" />
    </shortcut>
